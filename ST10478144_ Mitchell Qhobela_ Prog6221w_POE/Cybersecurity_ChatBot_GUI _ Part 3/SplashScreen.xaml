<Window x:Class="Cybersecurity_ChatBot_GUI.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Width="1400"
        Height="850"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        Topmost="True"
        ShowInTaskbar="False">

    <Grid>

        <!-- ================================================= -->
        <!-- BOT TITLE -->
        <!-- ================================================= -->

        <TextBlock Text="MQue Cybersecurity Bot"
                   Foreground="Lime"
                   FontSize="40"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,70,0,0"/>


        <!-- ================================================= -->
        <!-- ASCII ART -->
        <!-- ================================================= -->

        <TextBox x:Name="AsciiBox"
         FontFamily="Consolas"
         FontSize="9"
         Foreground="LightGreen"
         Background="Black"
         BorderThickness="0"
         IsReadOnly="True"
         TextWrapping="NoWrap"
         HorizontalScrollBarVisibility="Auto"
         VerticalScrollBarVisibility="Auto"
         Width="1250"
         Height="420"
         HorizontalAlignment="Center"
         VerticalAlignment="Center"/>


        <!-- ================================================= -->
        <!-- LOADING TEXT -->
        <!-- ================================================= -->

        <TextBlock Text="Loading Secure Chat Interface..."
                   Foreground="White"
                   FontSize="22"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,70"/>

    </Grid>

</Window>