<Window x:Class="Cybersecurity_ChatBot_GUI.MainWindow"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MQue Cybersecurity Bot"
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid Margin="10">

        <!-- ROWS -->
        <Grid.RowDefinitions>

            <!-- Header -->
            <RowDefinition Height="100"/>

            <!-- Chat Area -->
            <RowDefinition Height="*"/>

            <!-- Input Area -->
            <RowDefinition Height="70"/>

        </Grid.RowDefinitions>


        
        <!-- HEADER -->
        

        <Border Grid.Row="0"
                Background="#1E1E1E"
                CornerRadius="10"
                Padding="10"
                Margin="0,0,0,10">

            <Grid>

                <Grid.ColumnDefinitions>

                    <!-- ASCII -->
                    <ColumnDefinition Width="230"/>

                    <!-- Bot Name -->
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>


                <!-- ASCII LOGO -->
                <Border Grid.Column="0"
                        Background="#121212"
                        CornerRadius="8"
                        Padding="5"
                        Margin="0,0,10,0">

                    <TextBox x:Name="AsciiBox"
         FontFamily="Consolas"
         FontSize="2"
         Foreground="Lime"
         Background="#121212"
         BorderThickness="0"
         IsReadOnly="True"
         TextWrapping="NoWrap"
         VerticalScrollBarVisibility="Disabled"
         HorizontalScrollBarVisibility="Disabled"
         VerticalAlignment="Center"/>

                </Border>


                <!-- BOT DETAILS -->
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="MQue Cybersecurity Bot"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <TextBlock Text=" Online"
                               Foreground="LimeGreen"
                               FontSize="14"
                               Margin="0,5,0,0"/>

                </StackPanel>

            </Grid>

        </Border>


        
        
        

        <!-- CHAT HISTORY -->

        <Border Grid.Row="1"
        Background="#1E1E1E"
        CornerRadius="10"
        Padding="10"
        Margin="0,0,0,10">

            <ScrollViewer x:Name="ChatScrollViewer"
                  VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel"/>

            </ScrollViewer>

        </Border>


        
        <!-- INPUT AREA -->
        

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>

                <!-- Text Input -->
                <ColumnDefinition Width="*"/>

                <!-- Send Button -->
                <ColumnDefinition Width="120"/>

            </Grid.ColumnDefinitions>


            
            <!-- USER INPUT -->
            <TextBox x:Name="UserInputTextBox"
         Grid.Column="0"
         Height="45"
         FontSize="16"
         Padding="10"
         Margin="0,0,10,0"
         VerticalContentAlignment="Center"
         Background="#2A2A2A"
         Foreground="White"
         BorderBrush="LimeGreen"
         KeyDown="UserInputTextBox_KeyDown"/>


            <!-- SEND BUTTON -->
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="LimeGreen"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="SendButton_Click"/>

        </Grid>

    </Grid>

</Window>